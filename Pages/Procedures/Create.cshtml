@page
@inject ClinicManager.Services.IProcedureService ProcedureService
@using ClinicManager.DTOs
@using Microsoft.AspNetCore.Mvc

@functions {
    [BindProperty]
    public CreateProcedureRequest RequestData { get; set; } = new();

    public async Task<IActionResult> OnPostAsync()
    {
        if (!ModelState.IsValid)
        {
            return Page(); 
        }
        
        await ProcedureService.CreateAsync(RequestData);
        return RedirectToPage("./Index");
    }
}

<div class="container mt-5">
    <div class="card shadow-sm border-0" style="max-width: 600px; margin: 0 auto;">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">➕ Dodaj nową procedurę</h4>
        </div>
        <div class="card-body p-4">
            <form method="post">
                
                <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Opis zabiegu</label>
                    <input asp-for="RequestData.Description" class="form-control" placeholder="np. Konsultacja kardiologiczna" />
                    <span asp-validation-for="RequestData.Description" class="text-danger small fw-bold"></span>
                </div>
                
                <div class="mb-4">
                    <label class="form-label fw-bold">Koszt usługi (PLN)</label>
                    <input asp-for="RequestData.ServiceCost" type="text" class="form-control" placeholder="np. 150,00" />
                    <span asp-validation-for="RequestData.ServiceCost" class="text-danger small fw-bold"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-page="./Index" class="btn btn-outline-secondary">Powrót do listy</a>
                    <button type="submit" class="btn btn-success fw-bold">Zapisz do bazy</button>
                </div>

            </form>
        </div>
    </div>
</div>